@page
@model IndexModel
@{
    ViewData["Title"] = "LAN Chat";
}

<section class="join-page">
    <form id="joinForm" method="get" asp-page="/Chat" class="connection-panel">
        <div class="panel-title">Thông tin kết nối</div>

        <label class="field-row" for="serverHost">
            <span>IP server:</span>
            <input id="serverHost"
                   maxlength="120"
                   inputmode="url"
                   placeholder="192.168.1.10:5245" />
        </label>

        <label class="field-row" for="displayName">
            <span>Tên:</span>
            <input id="displayName"
                   name="displayName"
                   maxlength="80"
                   required
                   autocomplete="name"
                   value="User" />
        </label>

        <label class="field-row" for="roomName">
            <span>Phòng:</span>
            <input id="roomName"
                   name="roomName"
                   maxlength="100"
                   required
                   value="PRN222-Lab" />
        </label>

        <button class="connect-button" type="submit">Kết nối</button>
    </form>
</section>

@section Scripts {
    <script>
        (() => {
            const form = document.getElementById("joinForm");
            const serverHost = document.getElementById("serverHost");

            serverHost.value = window.location.host;

            form.addEventListener("submit", (event) => {
                const targetHost = normalizeHost(serverHost.value);

                if (!targetHost || targetHost === window.location.host) {
                    return;
                }

                event.preventDefault();

                const url = new URL(form.action, window.location.href);
                url.host = targetHost;

                const formData = new FormData(form);
                formData.delete("serverHost");
                url.search = new URLSearchParams(formData).toString();

                window.location.href = url.toString();
            });

            function normalizeHost(value) {
                value = value.trim();
                if (!value) {
                    return "";
                }

                try {
                    const url = value.includes("://")
                        ? new URL(value)
                        : new URL(`${window.location.protocol}//${value}`);

                    if (url.port || value.includes(":")) {
                        return url.host;
                    }

                    return `${url.hostname}:${window.location.port || "5245"}`;
                } catch {
                    return value;
                }
            }
        })();
    </script>
}
